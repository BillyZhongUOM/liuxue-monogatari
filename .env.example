# --- Pixel asset generation (optional) ---------------------------------------
# The game ships with CSS/SVG pixel placeholders and is fully playable WITHOUT
# any API key. Provide a key only if you want to regenerate the art assets.
#
# Image generation runs through OpenRouter, which exposes the "Nano Banana"
# Gemini flash-image model (google/gemini-3.1-flash-image-preview) and FLUX.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Image model id (default = Nano Banana / Gemini flash image)
IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# Hard cap on how many assets a single generation run may create (cost guard)
MAX_ASSET_GENERATIONS_PER_RUN=20

# NEVER commit a real key. This file is the example; copy to .env and fill in.
