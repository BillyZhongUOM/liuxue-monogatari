# --- Pixel asset generation (optional) ---------------------------------------
# The game is fully playable WITHOUT any key (emoji/CSS placeholders). A key is
# only needed to (re)generate pixel art.
#
# PRIMARY: Gemini API directly (no OpenRouter). `npm run generate:gemini` calls
# generativelanguage.googleapis.com with the native image models
# (gemini-3-pro-image / gemini-3.1-flash-image = "Nano Banana").
# Provide the key one of three ways: this var, GEMINI_KEY_FILE, or a key file.
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_KEY_FILE=/absolute/path/to/.gemini_key

# ALTERNATIVE: OpenRouter (`npm run generate:assets`). Get a key at
# https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# Hard cap on how many assets a single generation run may create (cost guard)
MAX_ASSET_GENERATIONS_PER_RUN=20

# NEVER commit a real key. This file is the example; copy to .env and fill in.
